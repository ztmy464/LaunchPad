# Template for foundry environment variables.
#
# PRODUCTION DEPLOYMENT CHECKLIST:
# 1. Copy this file to .env and fill in your actual values
# 2. Generate or import a deployer account: yarn account:generate OR yarn account:import
# 3. Fund the deployer account with ETH for gas
# 4. Deploy: yarn deploy --network mainnet
# 5. Verify contracts on Etherscan
#
# For local development, copy this file, rename it to .env, and fill in the values.

# We provide default values so developers can start prototyping out of the box,
# but we recommend getting your own API Keys for Production Apps.

# =============================================================================
# DEPLOYER ACCOUNT
# =============================================================================
# Use a keystore account for production deployments (more secure than raw private key)
# Generate with: yarn account:generate
# Import with: yarn account:import --private-key YOUR_KEY
# Default account for localhost / use "scaffold-eth-custom" for generated/imported account
LOCALHOST_KEYSTORE_ACCOUNT=scaffold-eth-default

# =============================================================================
# RPC PROVIDERS
# =============================================================================
# Alchemy API key for RPC access on mainnet/testnets
# Get yours at: https://dashboard.alchemyapi.io
ALCHEMY_API_KEY=

# =============================================================================
# CONTRACT VERIFICATION
# =============================================================================
# Etherscan API key for contract verification on Ethereum mainnet/testnets
# Get yours at: https://etherscan.io/myapikey
ETHERSCAN_API_KEY=

# Basescan API key for contract verification on Base
# Get yours at: https://basescan.org/myapikey
BASESCAN_API_KEY=
